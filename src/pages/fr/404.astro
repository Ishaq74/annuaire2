---
import BaseLayout from '@layouts/Layout.astro';
import { Button } from '@components/starwind/button';
import { Icon } from 'astro-icon/components';
import { getRelativeLocaleUrl } from 'astro:i18n';

// La langue est fixe pour ce fichier, car nous sommes dans le dossier /fr/
const lang = "fr";

const t = {
  title: 'Page non trouvée',
  code: '404',
  heading: 'Oups ! Cette page est partie en randonnée.',
  message: "Il semblerait que le lien que vous avez suivi soit cassé ou que la page ait été déplacée. Pas de panique, ça arrive !",
  home: 'Retour à l’accueil',
};

// Lien sûr vers la page d'accueil de la langue actuelle
const homeHref = getRelativeLocaleUrl(lang, '/');
---

<BaseLayout title={t.title}>
  <main class="flex-grow flex items-center justify-center">
    <div class="text-center py-16 px-4 sm:px-6 lg:px-8">
      
      <Icon name="openmoji:desert" class="h-24 w-24 md:h-32 md:w-32 mx-auto text-gray-300" />
      
      <p class="text-base font-semibold text-blue-600 uppercase tracking-wide mt-4">{t.code}</p>
      
      <h1 class="mt-2 text-4xl font-extrabold text-gray-900 tracking-tight sm:text-5xl">{t.heading}</h1>
      
      <p class="mt-4 text-base text-gray-500 max-w-lg mx-auto">{t.message}</p>
      
      <div class="mt-8">
        <Button href={homeHref} is="a" size="lg">
          <Icon name="openmoji:house" class="h-5 w-5 mr-2" />
          {t.home}
        </Button>
      </div>

    </div>
  </main>
</BaseLayout>
<style>
  /* On s'assure que le main prend bien toute la hauteur disponible entre le header et le footer */
  body {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
  }
</style>