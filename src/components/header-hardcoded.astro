---
import { Button } from "@components/starwind/button";
import {
  Dropdown,
  DropdownTrigger,
  DropdownContent,
  DropdownItem,
  DropdownLabel,
  DropdownSeparator,
} from "@components/starwind/dropdown";
import {
  Dialog,
  DialogTrigger,
  DialogContent,
  DialogClose,
} from "@components/starwind/dialog";
import { Avatar } from "@components/starwind/avatar"; // Assurez-vous d'avoir ce composant ou adaptez
import { Icon } from "astro-icon/components";

// NOUVEAU : Interface pour les liens individuels avec icône optionnelle
interface LinkItem {
  text: string;
  href: string;
  description?: string;
  iconName?: string; // Ajout pour les icônes de chaque lien
}

interface MenuItem {
  text: string;
  iconName: string; // Icone pour l'élément de menu principal (Découvrir, Activités, etc.)
  dropdown: {
    type: "simple" | "mega";
    content: Array<{
      label?: string;
      description?: string;
      items: LinkItem[]; // Utilise la nouvelle interface LinkItem
    }>;
  };
  active?: boolean;
}

const menuItems: MenuItem[] = [
  {
    text: "Découvrir",
    iconName: "openmoji:magnifying-glass-tilted-left",
    dropdown: {
      type: "simple",
      content: [
        {
          items: [
            { text: "Présentation générale", href: "/decouvrir/presentation", iconName: "openmoji:globe-with-meridians" },
            { text: "Histoire & Patrimoine", href: "/decouvrir/histoire", iconName: "openmoji:classical-building" },
            { text: "Points d'intérêt", href: "/decouvrir/points-interet", iconName: "openmoji:pushpin" },
            { text: "Plans et cartes", href: "/decouvrir/plans", iconName: "openmoji:world-map" },
          ],
        },
      ],
    },
  },
  {
    text: "Activités",
    iconName: "openmoji:running-shoe",
    dropdown: {
      type: "mega",
      content: [
        {
          label: "Outdoor",
          items: [
            { text: "Randonnée", href: "/activites/outdoor/randonnee", iconName: "openmoji:hiking-boot" },
            { text: "VTT", href: "/activites/outdoor/vtt", iconName: "openmoji:bicycle" },
            { text: "Sports nautiques", href: "/activites/outdoor/sports-nautiques", iconName: "openmoji:sailboat" },
            { text: "Ski / Snowboard", href: "/activites/outdoor/ski-snowboard", iconName: "openmoji:skis" },
            { text: "Parapente", href: "/activites/outdoor/parapente", iconName: "openmoji:parachute" },
          ],
        },
        {
          label: "Indoor",
          items: [
            { text: "Escalade en salle", href: "/activites/indoor/escalade", iconName: "openmoji:man-climbing" },
            { text: "Patinoire", href: "/activites/indoor/patinoire", iconName: "openmoji:ice-skate" },
            { text: "Bowling", href: "/activites/indoor/bowling", iconName: "openmoji:bowling" },
            { text: "Musées", href: "/activites/indoor/musees", iconName: "openmoji:temple-of-artemis-at-ephesus" },
          ],
        },
        {
          label: "Les Enfants",
          items: [
            { text: "Parcs de jeux", href: "/activites/enfants/parcs-jeux", iconName: "openmoji:playground-slide" },
            { text: "Activités ludiques", href: "/activites/enfants/activites-ludiques", iconName: "openmoji:building-construction" },
            { text: "Animations", href: "/activites/enfants/animations", iconName: "openmoji:party-popper" },
          ],
        },
      ],
    },
  },
  {
    text: "Gastronomie",
    iconName: "openmoji:fork-and-knife-with-plate",
    active: true,
    dropdown: {
      type: "mega",
      content: [
        {
          items: [
            {
              text: "Tous les restaurants",
              href: "/gastronomie/tous",
              description: "Découvrez tous les restaurants d'Annecy",
              iconName: "openmoji:cooking"
            },
          ],
        },
        {
          label: "Bars & Cafés",
          items: [
            { text: "Bars & Pubs", href: "/gastronomie/bars-pubs", iconName: "openmoji:beer-mug" },
            { text: "Cafés & Bistrots", href: "/gastronomie/cafes-bistrots", iconName: "openmoji:hot-beverage" },
            { text: "Fast Food", href: "/gastronomie/fast-food", iconName: "openmoji:hamburger" },
            { text: "Restaurants Asiatiques", href: "/gastronomie/asiatiques", iconName: "openmoji:sushi" },
          ],
        },
        {
          label: "Spécialités",
          items: [
            { text: "Boulangeries", href: "/gastronomie/boulangeries", iconName: "openmoji:baguette-bread" },
            { text: "Crêperies", href: "/gastronomie/creperies", iconName: "openmoji:pancakes" },
            { text: "Pizzerias", href: "/gastronomie/pizzerias", iconName: "openmoji:pizza" },
            { text: "Restaurants Gastronomiques", href: "/gastronomie/gastronomiques", iconName: "openmoji:cooked-rice" },
          ],
        },
      ],
    },
  },
  {
    text: "Hébergements",
    iconName: "openmoji:bed",
    dropdown: {
      type: "simple",
      content: [
        {
          items: [
            { text: "Hôtels", href: "/hebergements/hotels", iconName: "openmoji:hotel" },
            { text: "Campings", href: "/hebergements/campings", iconName: "openmoji:tent" },
            { text: "Chambres d'hôtes", href: "/hebergements/chambres-hotes", iconName: "openmoji:house-with-garden" },
            { text: "Locations saisonnières", href: "/hebergements/locations", iconName: "openmoji:house-with-garden" },
          ],
        },
      ],
    },
  },
  {
    text: "Services",
    iconName: "openmoji:toolbox",
    dropdown: {
      type: "simple",
      content: [
        {
          items: [
            { text: "Transports", href: "/services/transports", iconName: "openmoji:bus" },
                        { text: "Santé & Bien-être", href: "/services/sante-bien-etre", iconName: "openmoji:ambulance" },
            { text: "Commerces", href: "/services/commerces", iconName: "openmoji:shopping-bags" },
            { text: "Services publics", href: "/services/publics", iconName: "openmoji:office-building" },
          ],
        },
      ],
    },
  },
  {
    text: "Événements",
    iconName: "openmoji:calendar",
    dropdown: {
      type: "simple",
      content: [
        {
          items: [
            { text: "Agenda des événements", href: "/evenements/agenda", iconName: "openmoji:spiral-calendar" },
            { text: "Concerts & Spectacles", href: "/evenements/concerts-spectacles", iconName: "openmoji:performing-arts" },
            { text: "Expositions", href: "/evenements/expositions", iconName: "openmoji:framed-picture" },
            { text: "Festivals", href: "/evenements/festivals", iconName: "openmoji:admission-tickets" },
          ],
        },
      ],
    },
  },
  {
    text: "Communauté",
    iconName: "openmoji:people-dialogue",
    dropdown: {
      type: "simple",
      content: [
        {
          items: [
            { text: "Forum", href: "/communaute/forum", iconName: "openmoji:speech-balloon" },
            { text: "Groupes locaux", href: "/communaute/groupes", iconName: "openmoji:handshake" },
            { text: "Actualités locales", href: "/communaute/actualites", iconName: "openmoji:newspaper" },
          ],
        },
      ],
    },
  },
];

// NOUVEAU : Variable pour simuler l'état de connexion de l'utilisateur
// En production, cela viendrait d'un store, d'une session, etc.
const isUserLoggedIn = true; // Changez à false pour voir l'état déconnecté
const userName = "Jane Doe";
const userEmail = "jane.doe@example.com";
const userAvatarSrc = "https://i.pravatar.cc/150?img=3"; // Exemple d'avatar
---

<header class="bg-white border-b border-gray-200 px-6 py-4 flex items-center justify-between text-gray-700">
  <div class="flex items-center space-x-2">
    <a href="/" class="text-blue-600 text-lg font-bold">Annecy</a>
    <span class="text-gray-800 text-lg font-bold">Communautaire</span>
  </div>

  <nav class="hidden md:flex items-center space-x-6">
    {menuItems.map((item) => (
      <Dropdown openOnHover>
        <DropdownTrigger asChild>
          <button
            class={`font-medium flex items-center px-2 py-1 rounded group relative
              ${
                item.active
                  ? "text-blue-600 border-b-2 border-blue-600"
                  : "hover:text-blue-600 hover:border-b-2 hover:border-transparent"
              }
            `}
          >
            <Icon
              name={item.iconName}
              class="h-4 w-4 mr-1 text-gray-500 group-hover:text-blue-600"
            />
            <span>{item.text}</span>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-4 w-4 ml-1 text-gray-500 group-hover:text-blue-600 transition-transform duration-200 group-data-[state=open]:rotate-180"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
        </DropdownTrigger>

        {item.dropdown.type === "mega" ? (
          <DropdownContent
            side="bottom"
            align="start"
            class="p-6 bg-white rounded-lg shadow-xl border border-gray-100 mt-2 min-w-[500px] lg:min-w-[700px]"
          >
            {/* Gastronomie: Section "Tous les restaurants" avec description et séparateur */}
            {item.text === "Gastronomie" && item.dropdown.content[0].items[0] && (
              <>
                <a
                  href={item.dropdown.content[0].items[0].href}
                  class="block px-3 py-2 text-blue-600 font-semibold rounded-md hover:bg-gray-50 mb-2"
                >
                  {/* NOUVEAU : Icône pour le lien "Tous les restaurants" */}
                  {item.dropdown.content[0].items[0].iconName && (
                    <Icon name={item.dropdown.content[0].items[0].iconName} class="inline-block h-5 w-5 mr-2 align-middle text-gray-500" />
                  )}
                  {item.dropdown.content[0].items[0].text}
                </a>
                {item.dropdown.content[0].items[0].description && (
                  <p class="text-gray-500 text-sm px-3 mb-4">
                    {item.dropdown.content[0].items[0].description}
                  </p>
                )}
                <DropdownSeparator class="my-4" />
              </>
            )}

            {/* Grid principal pour les colonnes de contenu */}
            <div class={`grid gap-x-12 gap-y-4
                ${item.text === "Activités" ? "grid-cols-3" : "grid-cols-2"}
            `}>
              {/* Parcourt les sections de contenu (colonnes) */}
              {item.dropdown.content
                .slice(item.text === "Gastronomie" ? 1 : 0) // Exclut la première section pour Gastronomie (déjà affichée)
                .map((section) => (
                  <div>
                    {section.label && (
                      <DropdownLabel class="text-gray-700 font-semibold mb-2">
                        {section.label}
                      </DropdownLabel>
                    )}
                    <ul class="space-y-1">
                      {section.items.map((link) => (
                        <li>
                          <a
                            href={link.href}
                            class="group flex items-center text-gray-600 hover:text-blue-600 transition-colors"
                          >
                            {/* NOUVEAU : Icône pour chaque lien dans le mega-menu */}
                            {link.iconName && (
                              <Icon name={link.iconName} class="h-4 w-4 mr-2 text-gray-500 group-hover:text-blue-600" />
                            )}
                            {link.text}
                          </a>
                        </li>
                      ))}
                    </ul>
                  </div>
                ))}
            </div>
          </DropdownContent>
        ) : (
          /* Dropdown simple */
          <DropdownContent side="bottom" align="start" class="w-56 p-2 rounded-lg shadow-lg bg-white mt-2">
            {item.dropdown.content[0].items.map((link) => (
              <DropdownItem
                as="a"
                href={link.href}
                class="flex items-center w-full text-left px-3 py-2 text-gray-800 hover:bg-gray-50 hover:text-blue-600 rounded-md"
              >
                {/* NOUVEAU : Icône pour chaque lien dans le dropdown simple */}
                {link.iconName && (
                  <Icon name={link.iconName} class="h-4 w-4 mr-2 text-gray-500 group-hover:text-blue-600" />
                )}
                {link.text}
              </DropdownItem>
            ))}
          </DropdownContent>
        )}
      </Dropdown>
    ))}
  </nav>

  <div class="hidden md:flex items-center space-x-4">
    {isUserLoggedIn ? (
      <Dropdown>
        <DropdownTrigger asChild>
          <button class="relative flex items-center space-x-2 rounded-full p-1 -m-1 hover:bg-gray-100 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 transition-colors">
            <Avatar initials={userName.split(' ').map(n => n[0]).join('')} src={userAvatarSrc} alt={userName} class="h-8 w-8" />
            <span class="text-gray-700 font-medium hidden lg:inline">{userName}</span>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-4 w-4 text-gray-500 transition-transform duration-200 group-data-[state=open]:rotate-180"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
        </DropdownTrigger>
        <DropdownContent side="bottom" align="end" class="w-64 p-2 rounded-lg shadow-lg bg-white mt-2">
          <div class="px-3 py-2">
            <p class="font-semibold text-gray-800 truncate">{userName}</p>
            <p class="text-sm text-gray-500 truncate">{userEmail}</p>
          </div>
          <DropdownSeparator class="my-2" />
          <DropdownItem as="a" href="/profile" class="flex items-center w-full text-left px-3 py-2 text-gray-800 hover:bg-gray-50 hover:text-blue-600 rounded-md">
            <Icon name="openmoji:person" class="h-4 w-4 mr-2 text-gray-500" />
            Mon Profil
          </DropdownItem>
          <DropdownItem as="a" href="/settings" class="flex items-center w-full text-left px-3 py-2 text-gray-800 hover:bg-gray-50 hover:text-blue-600 rounded-md">
            <Icon name="openmoji:gear" class="h-4 w-4 mr-2 text-gray-500" />
            Paramètres
          </DropdownItem>
          <DropdownSeparator class="my-2" />
          <DropdownItem as="button" class="flex items-center w-full text-left px-3 py-2 text-gray-800 hover:bg-gray-50 hover:text-red-500 rounded-md">
            <Icon name="openmoji:door" class="h-4 w-4 mr-2 text-gray-500" />
            Déconnexion
          </DropdownItem>
        </DropdownContent>
      </Dropdown>
    ) : (
      <>
        <Button variant="outline" size="sm" as="a" href="/login">Connexion</Button>
        <Button size="sm" as="a" href="/register">Inscription</Button>
      </>
    )}
  </div>

  <Dialog>
    <DialogTrigger asChild>
      <button aria-label="Ouvrir le menu mobile" class="md:hidden p-2 rounded hover:bg-gray-100">
        <svg
          class="h-6 w-6 text-gray-700"
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </DialogTrigger>

    <DialogContent class="fixed inset-0 bg-white p-6 overflow-auto z-50">
      <div class="flex justify-between items-center mb-6">
        <div class="flex items-center space-x-2">
          <a href="/" class="text-blue-600 text-lg font-bold">Annecy</a>
          <span class="text-gray-800 text-lg font-bold">Communautaire</span>
        </div>
        <DialogClose asChild>
          <button class="p-2 rounded hover:bg-gray-100" aria-label="Fermer le menu mobile">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-6 w-6 text-gray-800"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </DialogClose>
      </div>

      <div class="mb-6 border-b border-gray-100 pb-4">
        {isUserLoggedIn ? (
          <div class="flex items-center space-x-3">
            <Avatar initials={userName.split(' ').map(n => n[0]).join('')} src={userAvatarSrc} alt={userName} class="h-10 w-10" />
            <div>
              <p class="font-semibold text-gray-800">{userName}</p>
              <p class="text-sm text-gray-500">{userEmail}</p>
            </div>
          </div>
        ) : (
          <div class="flex flex-col space-y-3">
            <Button variant="outline" as="a" href="/login">Connexion</Button>
            <Button as="a" href="/register">Inscription</Button>
          </div>
        )}
      </div>

      <nav class="space-y-4">
        {menuItems.map((item) => (
          // Utilisation de la balise <details> native pour le menu accordéon sur mobile.
          <details class="group border-b border-gray-100 pb-2">
            <summary class="flex items-center justify-between w-full font-medium text-gray-800 hover:text-blue-600 py-2 cursor-pointer">
              <div class="flex items-center space-x-2">
                <Icon name={item.iconName} class="h-5 w-5 text-gray-500" />
                <span class="text-lg">{item.text}</span>
              </div>
              <svg
                class="h-5 w-5 text-gray-500 transform transition-transform duration-200 group-open:rotate-180"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            {/* Contenu du dropdown mobile, correctement indenté */}
            <div class="pl-8 pt-2 pb-2">
              {item.dropdown.type === "mega" ? (
                <>
                  {/* Gastronomie: Lien "Tous les restaurants" en haut du mega-menu mobile */}
                  {item.text === "Gastronomie" && item.dropdown.content[0].items[0] && (
                    <a
                      href={item.dropdown.content[0].items[0].href}
                      class="flex items-center py-2 font-semibold text-blue-600 hover:bg-gray-50 rounded-md"
                    >
                      {/* NOUVEAU : Icône pour le lien "Tous les restaurants" mobile */}
                      {item.dropdown.content[0].items[0].iconName && (
                        <Icon name={item.dropdown.content[0].items[0].iconName} class="h-5 w-5 mr-2 text-gray-500" />
                      )}
                      {item.dropdown.content[0].items[0].text}
                    </a>
                  )}

                  {/* Sections de colonnes pour les mega-menus mobiles */}
                  {item.dropdown.content
                    .slice(item.text === "Gastronomie" ? 1 : 0)
                    .map((section) => (
                      <div class="mt-4 first:mt-0">
                        {section.label && <p class="font-semibold mb-1 text-gray-600">{section.label}</p>}
                        <ul class="space-y-1 ml-2">
                          {section.items.map((link) => (
                            <li>
                              <a
                                href={link.href}
                                class="flex items-center text-gray-700 hover:text-blue-600 py-1"
                              >
                                {/* NOUVEAU : Icône pour chaque lien dans le mega-menu mobile */}
                                {link.iconName && (
                                  <Icon name={link.iconName} class="h-4 w-4 mr-2 text-gray-500" />
                                )}
                                {link.text}
                              </a>
                            </li>
                          ))}
                        </ul>
                      </div>
                    ))}
                </>
              ) : (
                /* Dropdown simple pour mobile */
                <ul class="space-y-1 ml-2">
                  {item.dropdown.content[0].items.map((link) => (
                    <li>
                      <a href={link.href} class="flex items-center text-gray-700 hover:text-blue-600 py-1">
                        {/* NOUVEAU : Icône pour chaque lien dans le dropdown simple mobile */}
                        {link.iconName && (
                          <Icon name={link.iconName} class="h-4 w-4 mr-2 text-gray-500" />
                        )}
                        {link.text}
                      </a>
                    </li>
                  ))}
                </ul>
              )}
            </div>
          </details>
        ))}
      </nav>

      {/* NOUVEAU : Menu de profil pour mobile, si connecté */}
      {isUserLoggedIn && (
        <details class="group border-b border-gray-100 pb-2 mt-4">
          <summary class="flex items-center justify-between w-full font-medium text-gray-800 hover:text-blue-600 py-2 cursor-pointer">
            <div class="flex items-center space-x-2">
              <Icon name="openmoji:person" class="h-5 w-5 text-gray-500" />
              <span class="text-lg">Compte</span>
            </div>
            <svg
              class="h-5 w-5 text-gray-500 transform transition-transform duration-200 group-open:rotate-180"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <div class="pl-8 pt-2 pb-2 space-y-1 ml-2">
            <a href="/profile" class="flex items-center text-gray-700 hover:text-blue-600 py-1">
              <Icon name="openmoji:person" class="h-4 w-4 mr-2 text-gray-500" />
              Mon Profil
            </a>
            <a href="/settings" class="flex items-center text-gray-700 hover:text-blue-600 py-1">
              <Icon name="openmoji:gear" class="h-4 w-4 mr-2 text-gray-500" />
              Paramètres
            </a>
            <div class="border-t border-gray-100 my-2"></div>
            <button class="flex items-center w-full text-left text-gray-700 hover:text-red-500 py-1">
              <Icon name="openmoji:door" class="h-4 w-4 mr-2 text-gray-500" />
              Déconnexion
            </button>
          </div>
        </details>
      )}

      {/* Les boutons de connexion/inscription ont été déplacés plus haut si l'utilisateur n'est pas connecté */}
    </DialogContent>
  </Dialog>
</header>