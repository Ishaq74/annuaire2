---
export const prerender = false;

import Layout from '@layouts/Layout.astro';
import { Card, CardHeader, CardContent, CardTitle } from '@components/starwind/card';
import { Badge } from '@components/starwind/badge';
import { Avatar, AvatarFallback, AvatarImage } from '@components/starwind/avatar';
import { Button } from '@components/starwind/button';
import { Input } from '@components/starwind/input';
import { Icon } from 'astro-icon/components';
import { Breadcrumb, BreadcrumbItem, BreadcrumbLink, BreadcrumbSeparator } from '@components/starwind/breadcrumb';
import { getMagazineIndexPageData } from '@lib/magazine';
import PageHeader from '@components/blog/PageHeader.astro';
import ArticleCard from '@components/blog/ArticleCard.astro';
import NewsletterCard from '@components/blog/NewsletterCard.astro';
import ContributeCard from '@components/blog/ContributeCard.astro';
import CategoriesWithCount from '@components/blog/CategoriesWithCount.astro';

const { lang } = Astro.locals;
const { magazine_slug } = Astro.params;

// Get magazine data using the new service
let magazineData;
try {
  magazineData = await getMagazineIndexPageData(lang, magazine_slug as string);
} catch (error) {
  console.error('Error fetching magazine data:', error);
  // Handle 404 or redirect
  return new Response(null, { status: 404 });
}

const {
  pageTitle,
  pageDescription,
  pageIcon,
  parentCategorySlug,
  featuredArticles,
  recentArticles,
  sidebarCategories,
  sidebarPopularArticles
} = magazineData;

// Transform articles to match the expected interface for components
const transformedFeaturedArticles = featuredArticles.map(article => ({
  id: article.id,
  article_title: article.title,
  article_summary: article.summary,
  article_featured_image_url: article.featuredImageUrl,
  article_featured_image_alt: article.featuredImageAlt,
  article_seo_slug: article.seoSlug,
  publication_date: article.publicationDate,
  read_time_minutes: article.readTimeMinutes,
  view_count: article.viewCount,
  author_name: article.author.name,
  author_profile_image_url: article.author.profileImageUrl,
  author_bio: article.author.bio,
  category_id: article.category.id,
  category_name: article.category.name,
  category_seo_slug: article.category.seoSlug,
  category_icon_name: article.category.iconName,
}));

const transformedRecentArticles = recentArticles.map(article => ({
  id: article.id,
  article_title: article.title,
  article_summary: article.summary,
  article_featured_image_url: article.featuredImageUrl,
  article_featured_image_alt: article.featuredImageAlt,
  article_seo_slug: article.seoSlug,
  publication_date: article.publicationDate,
  read_time_minutes: article.readTimeMinutes,
  view_count: article.viewCount,
  author_name: article.author.name,
  author_profile_image_url: article.author.profileImageUrl,
  author_bio: article.author.bio,
  category_id: article.category.id,
  category_name: article.category.name,
  category_seo_slug: article.category.seoSlug,
  category_icon_name: article.category.iconName,
}));

const transformedSidebarCategories = sidebarCategories.map(cat => ({
  id: cat.id,
  name: cat.name,
  seo_slug: cat.seoSlug,
  articles_count: cat.articlesCount,
}));

const transformedSidebarPopularArticles = sidebarPopularArticles.map(article => ({
  id: article.id,
  article_title: article.title,
  article_summary: article.summary,
  article_featured_image_url: article.featuredImageUrl,
  article_featured_image_alt: article.featuredImageAlt,
  article_seo_slug: article.seoSlug,
  publication_date: article.publicationDate,
  read_time_minutes: article.readTimeMinutes,
  view_count: article.viewCount,
  author_name: article.author.name,
  author_profile_image_url: article.author.profileImageUrl,
  author_bio: article.author.bio,
  category_id: article.category.id,
  category_name: article.category.name,
  category_seo_slug: article.category.seoSlug,
  category_icon_name: article.category.iconName,
}));
---

<Layout title={pageTitle} description={pageDescription}>
  <main class="min-h-screen bg-gray-50">
    <!-- Breadcrumb Navigation -->
    <div class="bg-white border-b">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
        <Breadcrumb>
          <BreadcrumbItem>
            <BreadcrumbLink href={`/${lang}/`}>Accueil</BreadcrumbLink>
          </BreadcrumbItem>
          <BreadcrumbSeparator />
          <BreadcrumbItem>
            <span class="text-gray-500">{pageTitle}</span>
          </BreadcrumbItem>
        </Breadcrumb>
      </div>
    </div>

    <!-- Page Header -->
    <PageHeader 
      title={pageTitle}
      description={pageDescription}
      icon={pageIcon}
    />

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <div class="grid grid-cols-1 lg:grid-cols-4 gap-8">
        <!-- Main Content -->
        <div class="lg:col-span-3 space-y-12">
          <!-- Featured Articles -->
          {transformedFeaturedArticles.length > 0 && (
            <section>
              <h2 class="text-2xl font-bold text-gray-900 mb-6 flex items-center gap-2">
                <Icon name="openmoji:star" class="h-6 w-6" />
                À la une
              </h2>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                {transformedFeaturedArticles.map(article => (
                  <ArticleCard
                    article={article}
                    lang={lang}
                    magazineSlug={parentCategorySlug}
                    variantData="featured"
                    variantStyle="card"
                  />
                ))}
              </div>
            </section>
          )}

          <!-- Recent Articles -->
          <section>
            <h2 class="text-2xl font-bold text-gray-900 mb-6 flex items-center gap-2">
              <Icon name="openmoji:clock" class="h-6 w-6" />
              Articles récents
            </h2>
            {transformedRecentArticles.length > 0 ? (
              <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                {transformedRecentArticles.map(article => (
                  <ArticleCard
                    article={article}
                    lang={lang}
                    magazineSlug={parentCategorySlug}
                    variantData="recent"
                    variantStyle="card"
                  />
                ))}
              </div>
            ) : (
              <div class="text-center py-8">
                <Icon name="openmoji:desert" class="h-16 w-16 mx-auto text-gray-400 mb-4" />
                <p class="text-gray-600">Aucun article récent pour le moment.</p>
                <p class="text-gray-500 mt-2">Revenez bientôt ou explorez d'autres catégories !</p>
              </div>
            )}
          </section>
        </div>

        <!-- Sidebar -->
        <div class="lg:col-span-1 space-y-8">
          <!-- Categories -->
          <Card>
            <CardHeader>
              <CardTitle class="flex items-center gap-2">
                <Icon name="openmoji:file-folder" class="h-5 w-5" />
                Catégories
              </CardTitle>
            </CardHeader>
            <CardContent>
              {transformedSidebarCategories.length > 0 ? (
                <ul class="space-y-2">
                  {transformedSidebarCategories.map(category => (
                    <li>
                      <a 
                        href={`/${lang}/${parentCategorySlug}/${category.seo_slug}`}
                        class="flex justify-between items-center text-gray-600 hover:text-blue-600 font-medium p-2 -m-2 rounded-lg hover:bg-slate-50 transition-colors"
                      >
                        <span>{category.name}</span>
                        <Badge variant="secondary">{category.articles_count}</Badge>
                      </a>
                    </li>
                  ))}
                </ul>
              ) : (
                <p class="text-gray-500 text-sm">Aucune catégorie disponible.</p>
              )}
            </CardContent>
          </Card>

          <!-- Popular Articles -->
          {transformedSidebarPopularArticles.length > 0 && (
            <Card>
              <CardHeader>
                <CardTitle class="flex items-center gap-2">
                  <Icon name="openmoji:fire" class="h-5 w-5" />
                  Articles populaires
                </CardTitle>
              </CardHeader>
              <CardContent>
                <ul class="space-y-4">
                  {transformedSidebarPopularArticles.map(article => (
                    <li>
                      <ArticleCard
                        article={article}
                        lang={lang}
                        magazineSlug={parentCategorySlug}
                        variantData="popular"
                        variantStyle="compact"
                      />
                    </li>
                  ))}
                </ul>
              </CardContent>
            </Card>
          )}

          <!-- Newsletter -->
          <NewsletterCard />

          <!-- Contribute -->
          <ContributeCard />
        </div>
      </div>
    </div>
  </main>
</Layout>